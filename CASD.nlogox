  <experiments>
    <experiment name="Template Experiment" repetitions="1" sequentialRunOrder="true" runMetricsEveryStep="true">
      <setup>setup</setup>
      <go>go</go>
      <exitCondition>error?</exitCondition>
      <metrics>
        <metric>rng-seed</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="random-seed?">
          <value value="true"></value>
        </enumeratedValueSet>
      </constants>
    </experiment>
  </experiments>
